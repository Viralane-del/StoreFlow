@model IEnumerable<Todo>
@{
    ViewData["Title"] = "TodoConcat";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Yapılacaklar Listesi</h3>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Açıklama</th>
                                <th>Öncelik</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <th>@count</th>
                                    <td>@item.Description</td>
                                    @if (item.Priority == "Birincil")
                                    {
                                        <td class="text-success">@item.Priority</td>
                                    }
                                    @if (item.Priority == "İkincil")
                                    {
                                        <td class="text-warning">@item.Priority</td>
                                    }
                                    @if (item.Status == true)
                                    {
                                        <td class="text-info">@item.Status</td>
                                    }
                                    @if (item.Status == false)
                                    {
                                        <td class="text-danger">@item.Status</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

