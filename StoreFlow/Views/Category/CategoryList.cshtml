@model List<Category>
@{
    ViewData["Title"] = "CategoryList";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Kategori Listesi</h3>
                <p class="card-description">
                    <code style="font-weight:bold;">Kategori ile ilgili işlemlerinizi buradan yapabilirsiniz.</code>
                </p>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Kategori Adı</th>
                                <th>Durum</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <th>@item.CategoryId</th>
                                    <td>@item.CategoryName</td>
                                    @if (item.CategoryStatus == true)
                                    {
                                        <td><label class="badge badge-success badge-pill">Aktif Kategori</label></td>
                                    }
                                    else 
                                    {
                                        <td><label class="badge badge-danger badge-pill">Pasif Kategori</label></td>
                                    }
                                    <td><a href="/Category/DeleteCategory/@item.CategoryId" class="btn btn-outline-behance">Sil</a></td>
                                    <td><a href="/Category/UpdateCategory/@item.CategoryId"  class="btn btn-outline-dark">Güncelle</a></td>
                                </tr>
                            }                            
                        </tbody>
                    </table>
                    <a href="/Category/CreateCategory/" class="btn btn-outline-primary btn-fw">Yeni Kategori Ekle</a>
                </div>
            </div>
        </div>
    </div>
</div>
